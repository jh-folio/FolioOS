# Folio OS local settings template.
# Copy this file to .env, then fill in only the services you use.
# Never commit or share .env.

# Global AI Agent policy.
# AI_AGENT_ENABLED=1 uses the selected CLI/API path when possible.
# AI_AGENT_ENABLED=0 keeps Folio OS on local/rule-based fallback behavior.
AI_AGENT_ENABLED=1
AI_AGENT_MODE=cli

# Legacy compatibility switches kept in sync by the Settings UI.
USE_LLM_BRIEFING=1
USE_LLM_ANALYSIS=1

# LLM API mode. API keys are optional unless AI_AGENT_MODE=api.
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-5.5
OPENAI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=

# Generation limits and optional web-search augmentation.
USE_WEB_SEARCH_FOR_BRIEFING=1
USE_WEB_SEARCH_FOR_ANALYSIS=1
LLM_MAX_OUTPUT_TOKENS=7000
LLM_MEMORY_MAX_OUTPUT_TOKENS=2600
LLM_TIMEOUT_SECONDS=120
LLM_WEB_SEARCH_MAX_USES=5

# Local subscription CLI bridge. CLI authentication is stored by each CLI, not here.
AGENT_CLI_PROVIDER=auto
FOLIO_AGENT_CODEX_MODEL=
FOLIO_AGENT_CLAUDE_MODEL=
FOLIO_AGENT_ANTIGRAVITY_MODEL=
AGENT_CLI_TIMEOUT_SECONDS=1800
# FOLIO_AGENT_CODEX_COMMAND=C:\path\to\codex.exe
# FOLIO_AGENT_CLAUDE_COMMAND=C:\path\to\claude.exe
# FOLIO_AGENT_ANTIGRAVITY_COMMAND=C:\path\to\agy.exe

# SEC companyfacts API. SEC recommends a User-Agent with app/contact information.
SEC_USER_AGENT=FolioOS/0.1 your-email@example.com
SEC_TIMEOUT_SECONDS=30

# DART Open API for Korean company analysis.
DART_API_KEY=
DART_TIMEOUT_SECONDS=30

# Optional macro/market data providers.
FRED_API_KEY=
BOK_API_KEY=
TOSS_OPEN_API_CLIENT_ID=
TOSS_OPEN_API_CLIENT_SECRET=
TOSS_OPEN_API_BASE_URL=

# Optional export integrations.
NOTION_TOKEN=
NOTION_DB_ID=
